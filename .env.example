# Copy to .env and fill in real values before running docker compose

JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Razorpay — leave blank if not using payments yet
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# URL the frontend JS uses to reach the API
# In production, set this to your public API domain, e.g. https://api.gkpro.in/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# CORS origin the server allows
CLIENT_URL=http://localhost:3000
